// https://loccy.dev - AI-powered IDE extension to manage i18n with ease
{
  "resources": {
    "paths": {
      "include": ["messages/*/*.json"],
      "exclude": []
    },
    "locale": {
      "source": "folder",
      "pattern": "messages/{locale}/{namespace}.json"
    },
    "file": {
      "structure": "nested",
      "sortKeys": "no"
    }
  },
  "usages": {
    "paths": {
      "include": ["app/**/*.{js,ts,jsx,tsx}", "src/**/*.{js,ts,jsx,tsx}"],
      "exclude": ["node_modules"]
    },
    "tFunction": {
      "preset": "next-intl",
      "customFunctionNames": []
    },
    "detectKeysInStrings": true,
    "quoteType": "single"
  },
  "ai": {
    "translations": {
      "autoConsistency": true,
      "customInstructions": "",
      "customInstructionsPerLocale": {}
    },
    "keypaths": {
      "autoConsistency": true,
      "customInstructions": ""
    },
    "useCodeContext": true
  }
}
