{
  "name": "taskry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:no-lint": "next build --no-lint",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "prisma:generate": "dotenv -e .env.development -- prisma generate",
    "migrate:dev:reset": "dotenv -e .env.development -- prisma migrate reset",
    "migrate:dev": "dotenv -e .env.development -- prisma migrate dev",
    "migrate:prod": "dotenv -e .env.production -- prisma migrate deploy",
    "seed:dev": "dotenv -e .env.development -- tsx prisma/seed.ts",
    "build-storybook": "storybook build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:push:test": "npx dotenv -e .env.test -- npx prisma db push",
    "storybook": "storybook dev -p 6006",
    "test:smoke": "npm run test:prepare && npx dotenv -e .env.test -- start-server-and-test dev http://localhost:3000 \"cypress run --spec cypress/e2e/smoke/*.cy.ts\"",
    "test:ui": "vitest --project ui run",
    "test:prepare": "npm run docker:up && npm run db:push:test",
    "test:e2e": "npm run test:prepare && npx dotenv -e .env.test -- start-server-and-test dev http://localhost:3000 'cypress open'",
    "test:e2e:headless": "npm run test:prepare && npx dotenv -e .env.test -- start-server-and-test dev http://localhost:3000 'cypress run'",
    "test:db": "npm run test:prepare && npx dotenv -e .env.test -- vitest --pool=forks --poolOptions.forks.singleFork --project database run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.844.0",
    "@aws-sdk/s3-presigned-post": "^3.1007.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "15.3.6",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@react-aria/interactions": "^3.28.0",
    "@react-aria/utils": "^3.34.0",
    "@types/mdx": "^2.0.13",
    "better-auth": "1.4.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.536.0",
    "motion": "^12.23.12",
    "next": "15.3.8",
    "next-intl": "^4.5.5",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.5",
    "pg": "^8.16.3",
    "react": "^19.0.0",
    "react-aria": "^3.42.0",
    "react-aria-components": "^1.13.0",
    "react-avatar-editor": "^14.0.0",
    "react-dom": "^19.0.0",
    "react-responsive": "^10.0.1",
    "react-stately": "^3.40.0",
    "server-only": "^0.0.1",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1",
    "tailwindcss-react-aria-components": "^2.0.0",
    "use-debounce": "^10.1.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.0",
    "@eslint/eslintrc": "^3",
    "@react-aria/test-utils": "^1.0.0-beta.0",
    "@storybook/addon-a11y": "^9.1.1",
    "@storybook/addon-docs": "^9.1.1",
    "@storybook/addon-themes": "^9.1.1",
    "@storybook/addon-vitest": "^9.1.1",
    "@storybook/nextjs-vite": "^9.1.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^5.0.2",
    "@types/formidable": "^3.4.5",
    "@types/node": "^20.19.27",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "cypress": "^15.8.1",
    "eslint": "^9",
    "eslint-config-next": "15.3.5",
    "eslint-plugin-storybook": "^9.1.1",
    "jsdom": "^27.4.0",
    "playwright": "^1.54.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "prisma": "^7.1.0",
    "start-server-and-test": "^2.1.3",
    "storybook": "^9.1.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
