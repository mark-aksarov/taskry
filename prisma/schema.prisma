generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//Workspace

model Workspace {
  id Int @id @default(autoincrement())

  companies              Company[]
  projectCategories      ProjectCategory[]
  taskCategories         TaskCategory[]
  positions              Position[]
  messageThreads         MessageThread[]
  notificationRecipients NotificationRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("workspace")
}

// Attachments

model Attachment {
  id      Int    @id @default(autoincrement())
  fileUrl String

  projectAttachments        ProjectAttachment[]
  projectCommentAttachments ProjectCommentAttachment[]
  taskAttachments           TaskAttachment[]
  taskCommentAttachments    TaskCommentAttachment[]
  messageAttachments        MessageAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attachment")
}

//Company

model Company {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(200)

  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  customers Customer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("company")
}

// Customer

model Customer {
  id          Int     @id @default(autoincrement())
  fullName    String  @db.VarChar(100)
  bio         String?
  imageUrl    String?
  email       String  @db.VarChar(100)
  phoneNumber String? @db.VarChar(20)
  publicLink  String? @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId Int

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  projects            Project[]
  notificationTargets NotificationTarget[]

  @@index([companyId])
  @@map("customer")
}

// Project

model Project {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.VarChar(5000)
  deadline    DateTime

  creatorId  String?
  customerId Int?
  categoryId Int
  statusId   Int

  creator  User?           @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  customer Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  category ProjectCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  status   ProjectStatus   @relation(fields: [statusId], references: [id], onDelete: Cascade)

  members             ProjectMember[]
  attachments         ProjectAttachment[]
  tasks               Task[]
  projectComments     ProjectComment[]
  notificationTargets NotificationTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([creatorId])
  @@index([categoryId])
  @@index([statusId])
  @@map("project")
}

model ProjectCategory {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(100)

  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("project_category")
}

model ProjectStatus {
  id     Int    @id @default(autoincrement())
  nameEn String
  nameRu String

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_status")
}

model ProjectMember {
  projectId Int
  userId    String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([projectId, userId])
  @@map("project_member")
}

model ProjectAttachment {
  attachmentId Int
  projectId    Int

  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([attachmentId, projectId])
  @@map("project_attachment")
}

model ProjectComment {
  id      Int    @id @default(autoincrement())
  content String

  projectId Int
  senderId  String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id], onDelete: Cascade)

  attachments ProjectCommentAttachment[]
  reads       ProjectCommentRead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_comment")
}

model ProjectCommentRead {
  projectCommentId Int
  userId           String

  projectComment ProjectComment @relation(fields: [projectCommentId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  readAt DateTime @default(now())

  @@id([projectCommentId, userId])
  @@map("project_comment_user")
}

model ProjectCommentAttachment {
  attachmentId     Int
  projectCommentId Int

  attachment     Attachment     @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  projectComment ProjectComment @relation(fields: [projectCommentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([attachmentId, projectCommentId])
  @@map("project_comment_attachment")
}

// Task

model Task {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.VarChar(5000)
  deadline    DateTime

  projectId  Int
  creatorId  String?
  categoryId Int
  statusId   Int

  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator  User?        @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  category TaskCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  status   TaskStatus   @relation(fields: [statusId], references: [id], onDelete: Cascade)

  subtasks            Subtask[]
  attachments         TaskAttachment[]
  taskComments        TaskComment[]
  notificationTargets NotificationTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([creatorId])
  @@index([categoryId])
  @@index([statusId])
  @@map("task")
}

model TaskCategory {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(100)

  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("task_category")
}

model TaskStatus {
  id     Int    @id @default(autoincrement())
  nameEn String
  nameRu String

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("task_status")
}

model Subtask {
  id     Int     @id @default(autoincrement())
  name   String
  isDone Boolean

  taskId Int

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subtask")
}

model TaskAttachment {
  attachmentId Int
  taskId       Int

  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([attachmentId, taskId])
  @@map("task_attachment")
}

model TaskComment {
  id      Int    @id @default(autoincrement())
  content String

  taskId   Int
  senderId String

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  attachments TaskCommentAttachment[]
  reads       TaskCommentRead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("task_comment")
}

model TaskCommentRead {
  taskCommentId Int
  userId        String

  taskComment TaskComment @relation(fields: [taskCommentId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  readAt DateTime @default(now())

  @@id([taskCommentId, userId])
  @@map("task_comment_user")
}

model TaskCommentAttachment {
  attachmentId  Int
  taskCommentId Int

  attachment  Attachment  @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  taskComment TaskComment @relation(fields: [taskCommentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([attachmentId, taskCommentId])
  @@map("task_comment_attachment")
}

// Inbox

model MessageThread {
  id          Int @id @default(autoincrement())
  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("message_thread")
}

model Message {
  id   Int    @id @default(autoincrement())
  body String

  messageThreadId Int
  senderId        String
  receiverId      String

  thread   MessageThread @relation(fields: [messageThreadId], references: [id], onDelete: Cascade)
  sender   User          @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User          @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  attachments         MessageAttachment[]
  reads               MessageRead[]
  notificationTargets NotificationTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("message")
}

model MessageAttachment {
  attachmentId Int
  messageId    Int

  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  message    Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([attachmentId, messageId])
  @@map("message_attachment")
}

model MessageRead {
  messageId Int
  userId    String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  readAt DateTime @default(now())

  @@id([messageId, userId])
  @@index([messageId, userId])
  @@map("message_read")
}

// Notifications

enum NotificationType {
  TASK_ADDED
  TASK_DELETED
  TASK_UPDATED
  TASK_COMMENTED

  PROJECT_ADDED
  PROJECT_DELETED
  PROJECT_UPDATED
  PROJECT_COMMENTED

  USER_ADDED
  USER_DELETED
  USER_UPDATED

  CUSTOMER_ADDED
  CUSTOMER_DELETED
  CUSTOMER_UPDATED

  MESSAGE_SENDED
}

model Notification {
  id   Int              @id @default(autoincrement())
  type NotificationType

  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  targetId   Int?                @unique
  target     NotificationTarget? @relation(fields: [targetId], references: [id], onDelete: Cascade)
  targetName String?

  recipients NotificationRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification")
}

model NotificationTarget {
  id Int @id @default(autoincrement())

  userId     String? @unique
  customerId Int?    @unique
  projectId  Int?    @unique
  taskId     Int?    @unique
  messageId  Int?    @unique

  project  Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task     Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  message  Message?  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  notification Notification? @relation

  createdAt DateTime @default(now())

  @@map("notification_target")
}

model NotificationRecipient {
  notificationId Int
  userId         String
  isRead         Boolean   @default(false)
  readAt         DateTime?

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  Workspace    Workspace    @relation(fields: [workspaceId], references: [id])
  workspaceId  Int

  @@id([notificationId, userId])
  @@index([workspaceId])
  @@map("notification_recipient")
}

// User

model Position {
  id   Int    @id @default(autoincrement())
  name String

  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("position")
}

model User {
  id            String  @id
  name          String  @db.VarChar(100)
  role          String? @db.VarChar(50)
  email         String  @db.VarChar(100)
  emailVerified Boolean @default(false)
  imageUrl      String?
  phone         String? @db.VarChar(20)
  publicLink    String?

  positionId Int?

  position Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  projectMembers   ProjectMember[]
  projects         Project[]
  tasks            Task[]
  messagesSent     Message[]       @relation("Sender")
  messagesReceived Message[]       @relation("Receiver")
  sessions         Session[]
  accounts         Account[]

  projectComments        ProjectComment[]
  projectCommentReads    ProjectCommentRead[]
  taskComments           TaskComment[]
  taskCommentReads       TaskCommentRead[]
  messageReads           MessageRead[]
  notificationRecipients NotificationRecipient[]
  notifications          Notification[]
  notificationTargets    NotificationTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  ipAddress String?
  userAgent String?

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  accountId  String
  providerId String
  userId     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("verification")
}
