generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//Workspace

model Workspace {
  id Int @id @default(autoincrement())

  attachments       Attachment[]
  comments          Comment[]
  companies         Company[]
  customers         Customer[]
  projectCategories ProjectCategory[]
  projects          Project[]
  tasks             Task[]
  taskCategories    TaskCategory[]
  positions         Position[]
  users             User[]
  notifications     Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("workspace")
}

// Attachments

model Attachment {
  id        Int      @id @default(autoincrement())
  fileUrl   String
  fileName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commentId   Int?
  projectId   Int?
  taskId      Int?
  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  Comment   Comment?  @relation(fields: [commentId], references: [id])
  Project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Task      Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([taskId])
  @@index([commentId])
  @@map("attachment")
}

// Comments

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  senderId    String
  projectId   Int?
  taskId      Int?
  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sender    User      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  attachments         Attachment[]
  notificationTargets NotificationTarget[]

  @@index([projectId])
  @@index([taskId])
  @@map("comment")
}

//Company

model Company {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(200)

  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  customers Customer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("company")
}

// Customer

model Customer {
  id          Int     @id @default(autoincrement())
  fullName    String  @db.VarChar(100)
  bio         String?
  imageUrl    String?
  email       String  @db.VarChar(100)
  phoneNumber String? @db.VarChar(20)
  publicLink  String? @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId   Int
  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  projects            Project[]
  notificationTargets NotificationTarget[]

  @@index(workspaceId)
  @@map("customer")
}

// Project

model Project {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.VarChar(5000)
  deadline    DateTime

  creatorId   String?
  customerId  Int?
  categoryId  Int
  workspaceId Int

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User?           @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  customer  Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  category  ProjectCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  status    ProjectStatus

  attachments         Attachment[]
  tasks               Task[]
  comments            Comment[]
  notificationTargets NotificationTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("project")
}

model ProjectCategory {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(100)

  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index(workspaceId)
  @@map("project_category")
}

enum ProjectStatus {
  active
  pending
  completed
}

// Task

model Task {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.VarChar(5000)
  deadline    DateTime

  projectId   Int
  creatorId   String?
  assigneeId  String?
  categoryId  Int
  workspaceId Int

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator   User?        @relation("CreatedTasks", fields: [creatorId], references: [id], onDelete: SetNull)
  assignee  User?        @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  category  TaskCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  status    TaskStatus

  subtasks            Subtask[]
  attachments         Attachment[]
  comments            Comment[]
  notificationTargets NotificationTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index(workspaceId)
  @@map("task")
}

model TaskCategory {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(100)

  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index(workspaceId)
  @@map("task_category")
}

enum TaskStatus {
  active
  pending
  completed
}

model Subtask {
  id     Int     @id @default(autoincrement())
  text   String
  isDone Boolean

  taskId Int

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@map("subtask")
}

// Notifications

enum NotificationType {
  projectAdded
  projectDeadlineChanged
  projectStatusChanged
  projectDeleted

  taskAdded
  taskDeadlineChanged
  taskStatusChanged
  taskDeleted

  commentAdded
  commentChanged
  commentDeleted
}

model Notification {
  id   Int              @id @default(autoincrement())
  type NotificationType

  isRead Boolean @default(false)

  actorId String?
  actor   User?   @relation("Actor", fields: [actorId], references: [id], onDelete: SetNull)

  recipientId String?
  recipient   User?   @relation("Recipient", fields: [recipientId], references: [id], onDelete: SetNull)

  target  NotificationTarget?
  content String?

  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, recipientId])
  @@map("notification")
}

model NotificationTarget {
  id Int @id @default(autoincrement())

  userId     String?
  customerId Int?
  projectId  Int?
  taskId     Int?
  commentId  Int?

  project  Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task     Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  comment  Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  notificationId Int          @unique
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("notification_target")
}

// User

model Position {
  id   Int    @id @default(autoincrement())
  name String

  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  users     User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("position")
}

model User {
  id            String    @id
  fullName      String    @db.VarChar(100)
  bio           String?   @db.VarChar(5000)
  address       String?   @db.VarChar(255)
  birthdate     DateTime?
  role          String?   @db.VarChar(50)
  email         String    @db.VarChar(100)
  emailVerified Boolean   @default(false)
  imageUrl      String?
  phoneNumber   String?   @db.VarChar(20)
  publicLink    String?
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?

  positionId  Int?
  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  position  Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  projects      Project[]
  createdTasks  Task[]    @relation("CreatedTasks")
  assignedTasks Task[]    @relation("AssignedTasks")
  sessions      Session[]
  accounts      Account[]

  comments              Comment[]
  notificationsCreated  Notification[]       @relation("Actor")
  notificationsReceived Notification[]       @relation("Recipient")
  notificationTargets   NotificationTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email])
  @@index([workspaceId])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  accountId  String
  providerId String
  userId     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("verification")
}
