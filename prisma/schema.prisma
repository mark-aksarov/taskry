generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//Workspace

model Workspace {
  id Int @id @default(autoincrement())

  companies         Company[]
  projectCategories ProjectCategory[]
  taskCategories    TaskCategory[]
  positions         Position[]
  notifications     Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("workspace")
}

// Attachments

model Attachment {
  id        Int      @id @default(autoincrement())
  fileUrl   String
  fileName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commentId Int?
  projectId Int?
  taskId    Int?

  Comment Comment? @relation(fields: [commentId], references: [id])
  Project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Task    Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("attachment")
}

// Comments

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  senderId  String
  projectId Int?
  taskId    Int?
  parentId  Int?

  sender  User      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  project Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  attachments         Attachment[]
  likes               CommentLike[]
  notificationTargets NotificationTarget[]

  @@index([projectId])
  @@index([taskId])
  @@index([parentId])
  @@map("comment")
}

model CommentLike {
  id        Int      @id @default(autoincrement())
  commentId Int
  userId    String
  createdAt DateTime @default(now())

  comment    Comment   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Position   Position? @relation(fields: [positionId], references: [id])
  positionId Int?

  @@unique([commentId, userId])
  @@map("comment_like")
}

//Company

model Company {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(200)

  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  customers Customer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("company")
}

// Customer

model Customer {
  id          Int     @id @default(autoincrement())
  fullName    String  @db.VarChar(100)
  bio         String?
  imageUrl    String?
  email       String  @db.VarChar(100)
  phoneNumber String? @db.VarChar(20)
  publicLink  String? @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId Int

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  projects            Project[]
  notificationTargets NotificationTarget[]

  @@index([companyId])
  @@map("customer")
}

// Project

model Project {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.VarChar(5000)
  deadline    DateTime

  creatorId  String?
  customerId Int?
  categoryId Int
  statusId   String

  creator  User?           @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  customer Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  category ProjectCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  status   ProjectStatus   @relation(fields: [statusId], references: [id], onDelete: Cascade)

  attachments         Attachment[]
  tasks               Task[]
  comments            Comment[]
  notificationTargets NotificationTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId])
  @@index([customerId])
  @@index([categoryId])
  @@index([statusId])
  @@map("project")
}

model ProjectCategory {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(100)

  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("project_category")
}

model ProjectStatus {
  id     String @id
  nameEn String
  nameRu String

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_status")
}

// Task

model Task {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.VarChar(5000)
  deadline    DateTime

  projectId  Int
  creatorId  String?
  assigneeId String?
  categoryId Int
  statusId   String

  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator  User?        @relation("CreatedTasks", fields: [creatorId], references: [id], onDelete: SetNull)
  assignee User?        @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  category TaskCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  status   TaskStatus   @relation(fields: [statusId], references: [id], onDelete: Cascade)

  subtasks            Subtask[]
  attachments         Attachment[]
  comments            Comment[]
  notificationTargets NotificationTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([creatorId])
  @@index([assigneeId])
  @@index([categoryId])
  @@index([statusId])
  @@map("task")
}

model TaskCategory {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(100)

  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("task_category")
}

model TaskStatus {
  id     String @id
  nameEn String
  nameRu String

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("task_status")
}

model Subtask {
  id       Int      @id @default(autoincrement())
  name     String
  isDone   Boolean
  deadline DateTime

  taskId Int

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subtask")
}

// Notifications

enum NotificationType {
  TASK_ADDED
  TASK_DELETED
  TASK_UPDATED

  PROJECT_ADDED
  PROJECT_DELETED
  PROJECT_UPDATED

  USER_ADDED
  USER_DELETED
  USER_UPDATED

  CUSTOMER_ADDED
  CUSTOMER_DELETED
  CUSTOMER_UPDATED

  COMMENT_REPLIED
  COMMENT_ADDED
}

model Notification {
  id   Int              @id @default(autoincrement())
  type NotificationType

  isRead Boolean @default(false)

  actorId String?
  actor   User?   @relation("Actor", fields: [actorId], references: [id], onDelete: SetNull)

  recipientId String?
  recipient   User?   @relation("Recipient", fields: [recipientId], references: [id], onDelete: SetNull)

  targetId   Int?                @unique
  target     NotificationTarget? @relation(fields: [targetId], references: [id], onDelete: Cascade)
  targetName String?

  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("notification")
}

model NotificationTarget {
  id Int @id @default(autoincrement())

  userId     String? @unique
  customerId Int?    @unique
  projectId  Int?    @unique
  taskId     Int?    @unique
  commentId  Int?    @unique

  project  Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task     Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  comment  Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  notification Notification? @relation

  createdAt DateTime @default(now())

  @@map("notification_target")
}

// User

model Position {
  id   Int    @id @default(autoincrement())
  name String

  workspaceId Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  users        User[]
  commentLikes CommentLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("position")
}

model User {
  id            String    @id
  fullName      String    @db.VarChar(100)
  bio           String?   @db.VarChar(5000)
  address       String?   @db.VarChar(255)
  birthdate     DateTime?
  role          String?   @db.VarChar(50)
  email         String    @db.VarChar(100)
  emailVerified Boolean   @default(false)
  imageUrl      String?
  phoneNumber   String?   @db.VarChar(20)
  publicLink    String?

  positionId Int?

  position Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  projects      Project[]
  createdTasks  Task[]    @relation("CreatedTasks")
  assignedTasks Task[]    @relation("AssignedTasks")
  sessions      Session[]
  accounts      Account[]

  comments              Comment[]
  notificationsCreated  Notification[]       @relation("Actor")
  notificationsReceived Notification[]       @relation("Recipient")
  notificationTargets   NotificationTarget[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  CommentLike CommentLike[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  ipAddress String?
  userAgent String?

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  accountId  String
  providerId String
  userId     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("verification")
}
